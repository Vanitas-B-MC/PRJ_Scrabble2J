<Window x:Class="Scrabble2Joueurs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scrabble2Joueurs"
        mc:Ignorable="d"
        Title="JEU DU SCRABBLE - MODE 2 JOUEURS" Height="450" Width="800" ResizeMode="NoResize">
    <Window.Resources>
        <!-- Style de base -->
        <Style x:Key="BaseStyle">
            <Setter Property="Control.FontWeight" Value="DemiBold" />
            <Setter Property="Control.Margin" Value="5" />
        </Style>
        <!-- Style pour TextBox basé sur le style de base -->
        <Style TargetType="TextBox" BasedOn="{StaticResource BaseStyle}">
            <Setter Property="Padding" Value="1" />
            <Setter Property="Background" Value="#FFF0EBEB" />
            <Setter Property="Height" Value="22"/>
        </Style>
        <!-- Style pour Label basé sur le style de base -->
        <Style TargetType="Label" BasedOn="{StaticResource BaseStyle}">
            <Setter Property="Control.FontSize" Value="14" />
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Style pour TextBlock basé sur le style de base -->
        <Style TargetType="TextBlock" BasedOn="{StaticResource BaseStyle}">
            <Setter Property="Background" Value="#FFF0EBEB" />
            <Setter Property="Height" Value="22"/>
        </Style>
        <!-- Style pour Button basé sur le style de base -->
        <Style TargetType="Button" BasedOn="{StaticResource BaseStyle}">
            <Setter Property="Background" Value="#FF6892B3" />
            <Setter Property="Foreground" Value="#FFF0EBEB"  />
            <Setter Property="Height" Value="22"/>
            <Setter Property="Width" Value="100"/>
        </Style>
        <Style x:Key="StyleBorder" TargetType="Border">
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>
    <Grid >
        <Grid.Background>
            <ImageBrush ImageSource="/backgroundImg/Poogie.jpg" Stretch="UniformToFill" Opacity="0.70"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="Deb" Grid.Row="0" Margin="0,0,0,256" Grid.RowSpan="2" >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Name="Lettres" Visibility="Collapsed">
                <Viewbox Width="60" Height="60">
                    <TextBlock x:Name="Letter1" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
                <Viewbox Width="60" Height="60">
                    <TextBlock x:Name="Letter2" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
                <Viewbox Width="60" Height="60">
                    <TextBlock x:Name="Letter3" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
                <Viewbox Width="60" Height="60">
                    <TextBlock x:Name="Letter4" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
                <Viewbox Width="60" Height="60">
                    <TextBlock x:Name="Letter5" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
                <Viewbox Width="60" Height="60">
                    <TextBlock x:Name="Letter6" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
                <Viewbox Width="60" Height="60">
                    <TextBlock x:Name="Letter7" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
            </StackPanel>
            <Grid x:Name="DebutPartie">
                <Label x:Name="aDeleteJ1" Content="Entrez le nom du Joueur 1" HorizontalAlignment="Left" Margin="100,15,0,0" VerticalAlignment="Top" FontWeight="ExtraBlack" Foreground="Black"/>
                <TextBox x:Name="txtNomJ1" HorizontalAlignment="Left" Margin="300,20,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="217" BorderThickness="0,0,0,0" Initialized="start" GotFocus="focusOnTxtNomJ1" />
                <Label x:Name="aDeleteJ2" Content="Entrez le nom du Joueur 2" HorizontalAlignment="Left" Margin="100,45,0,0" VerticalAlignment="Top" FontWeight="ExtraBlack"/>
                <TextBox x:Name="txtNomJ2" HorizontalAlignment="Left" Margin="300,50,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="217" BorderThickness="0,0,0,0" Initialized="start2" GotFocus="gotFocusOnTxtNomJ2"/>
                <Button x:Name="btnCommencer" Content="COMMENCER" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="600,20,0,0" Click="startGame" Background="#FF1E82FF" Height="52" Width="161" />
            </Grid>
        </Grid>

        <Grid x:Name="Partie" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <!-- Joueur 1 -->
            <Border x:Name="BordureJoueur1" Grid.Column="0 " BorderBrush="#FF6892B3" Visibility="Visible" BorderThickness="2" Background="Transparent">
                <Grid x:Name="PartieJoueur1" Background="Transparent" Visibility="visible">
                    <Button x:Name="Joueur1play" Content="Valider le mot" HorizontalAlignment="Center" Margin="0,213,0,0" VerticalAlignment="Top" Background="#FF007B02" Click="Button_Click_J1" Visibility="Hidden" />
                    <Label x:Name="AfficheurNomJ1" Content="Poogie" HorizontalAlignment="Center" Margin="0,13,0,0" VerticalAlignment="Top" Visibility="Hidden"/>
                    <Label x:Name="nbrMotJ1" Content="0/10" HorizontalAlignment="Center" Margin="0,167,0,0" VerticalAlignment="Top" Visibility="Hidden"/>
                    <TextBlock FontSize="48" Background="PaleVioletRed" TextAlignment="Center" FontWeight="ExtraBlack" HorizontalAlignment="Center" TextWrapping="Wrap" x:Name="txtTotalPointsJ1" VerticalAlignment="Top" Height="110" Width="100" Margin="0,43,0,0" Visibility="Hidden"><Run Language="fr-fr" Text="0"/></TextBlock>
                </Grid>

            </Border>

            <!-- Joueur 2 -->
            <Border x:Name="BordureJoueur2" Grid.Column="1" BorderBrush="#FF6892B3" BorderThickness="2" Background="Transparent">
                <Grid x:Name="PartieJoueur2" Background="Transparent">
                    <Button x:Name="Joueur2play" Content="Valider le mot" HorizontalAlignment="Center" Margin="0,213,0,0" VerticalAlignment="Top" BorderThickness="0,1,1,1" Background="#FF007B02" Click="Button_Click_J2" Visibility="Hidden"/>
                    <Label x:Name="AfficheurNomJ2" Visibility="Hidden" Content="Tu n'est pas senser voir ça" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top"/>
                    <Label x:Name="nbrMotJ2" Content="0/10" HorizontalAlignment="Center" Margin="0,167,0,0" VerticalAlignment="Top" Visibility="Hidden"/>
                    <TextBlock Background="LightCyan" FontSize="48" TextAlignment="Center" FontWeight="ExtraBlack" HorizontalAlignment="Center" TextWrapping="Wrap" x:Name="txtTotalPointsJ2" VerticalAlignment="Top" Height="110" Width="100" Margin="0,40,0,0" Visibility="Hidden"><Run Language="fr-fr" Text=""/></TextBlock>
                </Grid>
            </Border>
        </Grid>
        <Grid x:Name="FinPartie" Grid.Row="2">
            <Label Content="nbManches" HorizontalAlignment="Left" VerticalAlignment="Center" Width="100" Margin="10,0,0,0" Visibility="Hidden"/>
            <TextBox HorizontalAlignment="Center" x:Name="txtMot" VerticalAlignment="Center" Width="400" Height="52" TextWrapping="Wrap" Text="" Visibility="Hidden" GotFocus="focusOnTxtxMot" LostFocus="lostFocusOnTxtMot" Initialized="txtMot_init" />
        </Grid>
    </Grid>
</Window>
